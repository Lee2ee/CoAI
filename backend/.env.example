# Copy this file to .env and fill in your values
# cp .env.example .env

# ── Ports ────────────────────────────────────────────────────────────────────
BACKEND_PORT=8000
FRONTEND_PORT=5173

# ── Application ──────────────────────────────────────────────────────────────
APP_NAME=CoAI Trading System
DEBUG=false

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./coai.db

# ── Security ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=change-me-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=10080   # 7 days

# ── Trading ──────────────────────────────────────────────────────────────────
DEFAULT_EXCHANGE=upbit
PAPER_TRADING_DEFAULT=true          # Must be true until strategy is validated

# Risk limits
MAX_POSITION_SIZE_PCT=10.0          # Max % of portfolio per position
MAX_DAILY_LOSS_PCT=5.0              # Circuit breaker: stop trading after this daily loss

# ── AI Provider ──────────────────────────────────────────────────────────────
# Choose one: "ollama" (free local) | "groq" (free API) | "anthropic" (paid)
AI_PROVIDER=ollama

# Ollama — free, runs locally (https://ollama.com)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Groq — free tier API (https://console.groq.com)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Anthropic — paid API (https://console.anthropic.com)
ANTHROPIC_API_KEY=
